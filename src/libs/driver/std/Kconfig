# HC32 Device Driver Library (DDL) 模块配置

menu "HC32 DDL Config"

config LL_ICG_ENABLE
    bool "ICG"
    default y
    help
        Initialization configuration.
        Hardware behavior that automatically initializes after hardware startup.

config LL_UTILITY_ENABLE
    bool "Utility"
    default y
    help
        Device Driver Library utility module.

config LL_PRINT_ENABLE
    bool "Print"
    default n
    help
        Enable DDL printf function support.

