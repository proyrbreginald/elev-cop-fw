CONFIG_PROJECT_NAME="PD-Embedded"
CONFIG_PROJECT_VERSION="0.1.0"
CONFIG_HC32F460=y

#
# HC32 DDL Config
#
CONFIG_LL_ICG_ENABLE=y
CONFIG_LL_UTILITY_ENABLE=y
# CONFIG_LL_PRINT_ENABLE is not set
# CONFIG_LL_ADC_ENABLE is not set
# CONFIG_LL_AES_ENABLE is not set
# CONFIG_LL_AOS_ENABLE is not set
# CONFIG_LL_CAN_ENABLE is not set
CONFIG_LL_CLK_ENABLE=y
# CONFIG_LL_CMP_ENABLE is not set
# CONFIG_LL_CRC_ENABLE is not set
# CONFIG_LL_DBGC_ENABLE is not set
# CONFIG_LL_DCU_ENABLE is not set
# CONFIG_LL_DMA_ENABLE is not set
CONFIG_LL_EFM_ENABLE=y
# CONFIG_LL_EMB_ENABLE is not set
# CONFIG_LL_EVENT_PORT_ENABLE is not set
CONFIG_LL_FCG_ENABLE=y
# CONFIG_LL_FCM_ENABLE is not set
CONFIG_LL_GPIO_ENABLE=y
# CONFIG_LL_HASH_ENABLE is not set
# CONFIG_LL_I2C_ENABLE is not set
# CONFIG_LL_I2S_ENABLE is not set
CONFIG_LL_INTERRUPTS_ENABLE=y
# CONFIG_LL_INTERRUPTS_SHARE_ENABLE is not set
# CONFIG_LL_KEYSCAN_ENABLE is not set
# CONFIG_LL_MPU_ENABLE is not set
# CONFIG_LL_OTS_ENABLE is not set
CONFIG_LL_PWC_ENABLE=y
# CONFIG_LL_QSPI_ENABLE is not set
# CONFIG_LL_RMU_ENABLE is not set
# CONFIG_LL_RTC_ENABLE is not set
# CONFIG_LL_SDIOC_ENABLE is not set
# CONFIG_LL_SPI_ENABLE is not set
CONFIG_LL_SRAM_ENABLE=y
# CONFIG_LL_SWDT_ENABLE is not set
# CONFIG_LL_TMR0_ENABLE is not set
# CONFIG_LL_TMR4_ENABLE is not set
# CONFIG_LL_TMR6_ENABLE is not set
# CONFIG_LL_TMRA_ENABLE is not set
# CONFIG_LL_TRNG_ENABLE is not set
CONFIG_LL_USART_ENABLE=y
# CONFIG_LL_USB_ENABLE is not set
# CONFIG_LL_WDT_ENABLE is not set
# end of HC32 DDL Config

#
# BSP Config
#
CONFIG_BSP_BOARD="hc32f460_core"
CONFIG_BSP_USING_TIMER=y
CONFIG_BSP_USING_GPIO=y
# end of BSP Config
