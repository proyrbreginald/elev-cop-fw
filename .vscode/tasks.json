// https://code.visualstudio.com/api/references/icons-in-labels 获取图标名称
// 本工程使用 Meson 构建系统，交叉编译目标：ARM Cortex-M4 (HC32F460)
// 构建目录: build/  (已使用 cross_file.txt 配置)
{
    "version": "2.0.0",
    "tasks":[
        // 1. 虚拟环境检查与配置
        {
            "label": "Venv",
            "type": "shell",
            "command": "./script/venv.sh",
            "group": "build",
            "presentation": { "reveal": "silent" },
            "options": {
              "statusbar": {
                "label": "$(python) Venv",
                "detail" : "虚拟环境检查与配置"
              }
            }
        },

        // 2. 交互式配置与裁剪代码
        {
            "label": "Menuconfig",
            "type": "shell",
            "command": "./script/menuconfig.sh",
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(preview) Menuconfig",
                "detail" : "交互式配置与裁剪代码"
              }
            }
        },

        // 3. 生成配置头文件
        {
            "label": "Genconfig",
            "type": "shell",
            "command": "./script/genconfig.sh",
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(file-code) Genconfig",
                "detail" : "生成配置头文件"
              }
            }
        },

        // 4. 清理构建目录
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm -rf build",
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(trash) Clean",
                "detail" : "清理构建目录"
              }
            }
        },

        // 5. 生成构建系统
        {
            "label": "Setup",
            "type": "shell",
            "command": "meson setup build --cross-file cross_file.txt",
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(gear) Setup",
                "detail" : "生成构建系统"
              }
            }
        },

        // 6. 执行交叉编译
        {
            "label": "Build",
            "type": "shell",
            "command": "meson compile -C build",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(debug-alt) Build",
                "detail" : "执行交叉编译"
              }
            }
        },

        // 7. 输出程序段信息
        {
            "label": "Info",
            "type": "shell",
            "command": "size -A ./build/pd-embedded.elf",
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(info) Info",
                "detail" : "输出程序段信息"
              }
            }
        },

        // 8. 生成镜像文件
        {
            "label": "Bin",
            "type": "shell",
            "command": "ninja -C build pd-embedded.hex pd-embedded.bin",
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(archive) Bin",
                "detail" : "生成镜像文件"
              }
            }
        },

        // 9. 烧录任务
        {
            "label": "Flash",
            "type": "shell",
            "command": ".venv/bin/pyocd flash --target hc32f460xe --erase chip ./build/pd-embedded.elf",
            "dependsOn": ["Venv"],
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(chip) Flash",
                "detail" : "烧录 ELF 镜像"
              }
            }
        },

        // 10. 组合任务
        {
            "label": "Auto",
            "type": "shell",
            "dependsOn": ["Clean", "Setup", "Build", "Info", "Flash"],
            "dependsOrder": "sequence",
            "group": "build",
            "presentation": { "reveal": "always" },
            "options": {
              "statusbar": {
                "label": "$(zap) Auto",
                "detail" : "自动执行流"
              }
            }
        }
    ]
}